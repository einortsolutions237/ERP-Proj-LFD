rules_version = '2';

// Test-only rules for the Firestore emulator (Phase 20.1 automated test suite).
//
// All application-layer tests exercise route handlers via the Admin SDK,
// which bypasses firestore.rules entirely in production and over the
// emulator's default gRPC transport. This project's Firestore emulator
// tests use REST transport instead (db.settings({ preferRest: true }),
// applied in tests/setup/env.ts) to work around a gRPC/Java-emulator
// connection-reset issue on Windows — but the Admin SDK's automatic
// "Bearer owner" rules-bypass only fires over gRPC, not REST. These
// permissive rules restore that bypass for the emulator only. The real
// firestore.rules (default-deny, deployed to production) is untouched —
// this phase does not test Firestore rules, only application-layer logic.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
