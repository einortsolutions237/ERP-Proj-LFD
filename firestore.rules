rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /auditLogs/{logId} {
      // keep in sync with ROLE_CAPABILITIES['admin.auditLog.view'] (ADMIN_IT) in src/lib/auth/permissions.ts
      allow read: if request.auth != null
        && request.auth.token.role in ['super_admin', 'admin', 'it_admin'];
      allow write: if false; // Admin SDK bypasses rules entirely; no client path, ever
    }
    match /staff/{staffId} {
      // keep in sync with ROLE_CAPABILITIES['admin.staff.view'] (ADMIN_HR) in src/lib/auth/permissions.ts
      allow read: if request.auth != null
        && request.auth.token.branchId == resource.data.branchId
        && request.auth.token.role in ['super_admin', 'admin', 'hr_admin'];
      allow create, update, delete: if false; // all writes go through Admin SDK via /api/staff
    }
    match /departments/{departmentId} {
      allow read: if request.auth != null
        && request.auth.token.branchId == resource.data.branchId;
      allow write: if false; // all writes go through Admin SDK via /api/departments
    }
    match /branches/{branchId} {
      // No branchId field to scope against here — a branch document IS the
      // branch. Any authenticated user can read the full list (needed for
      // e.g. staff creation forms elsewhere); only Admin SDK can write.
      allow read: if request.auth != null;
      allow write: if false; // all writes go through Admin SDK via /api/branches
    }
    match /suppliers/{supplierId} {
      allow read: if request.auth != null;
      allow write: if false; // all writes go through Admin SDK via /api/suppliers
    }
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if false; // all writes go through Admin SDK via /api/products
    }
    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if false; // all writes go through Admin SDK via /api/services
    }
    match /settings/{key} {
      allow read: if request.auth != null;
      allow write: if false; // all writes go through Admin SDK via /api/settings
    }
    match /rateLimits/{key} {
      allow read, write: if false; // Admin SDK only, no client path at all
    }
    match /productStock/{docId} {
      allow read: if request.auth != null
        && request.auth.token.branchId == resource.data.branchId;
      allow write: if false; // all writes go through Admin SDK via /api/stock/movements and /api/stock/transfer
    }
    match /stockMovements/{movementId} {
      allow read: if request.auth != null
        && request.auth.token.branchId == resource.data.branchId;
      allow write: if false; // all writes go through Admin SDK via /api/stock/movements and /api/stock/transfer
    }
    match /sales/{saleId} {
      allow read: if request.auth != null
        && request.auth.token.branchId == resource.data.branchId;
      allow write: if false; // all writes go through Admin SDK via /api/sales
    }
    match /customers/{customerId} {
      allow read: if request.auth != null;
      allow write: if false; // all writes go through Admin SDK via /api/customers
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
